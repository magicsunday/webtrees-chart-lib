{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "lib": ["ES2022", "DOM"],
        "types": ["jest"],
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "src/*": ["./src/*"],
            "d3-axis": ["./src/types/d3-axis.d.ts"],
            "d3-sankey": ["./src/types/d3-sankey.d.ts"]
        }
    },
    "include": ["src/**/*.js", "src/**/*.d.ts"]
}
