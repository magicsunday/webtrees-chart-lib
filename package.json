{
    "name": "@magicsunday/webtrees-chart-lib",
    "version": "1.8.0",
    "description": "Shared D3-based JavaScript chart library for the magicsunday/webtrees-* chart modules — 16 widget primitives (donut, world-map, progress-list, bar, line, stacked, diverging, chord, sankey, stream, name-bubbles, month-radial, mirror, gauge, area-density, box-plot) plus SVG zoom and export, color helpers, and localStorage form persistence.",
    "type": "module",
    "module": "dist/webtrees-chart-lib.es.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/webtrees-chart-lib.es.js"
        },
        "./chart-core": {
            "types": "./dist/types/chart-core.d.ts",
            "import": "./dist/webtrees-chart-lib-chart-core.es.js"
        }
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "rollup --config && tsc -p tsconfig.dts.json",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
        "lint": "biome lint --error-on-warnings src/ tests/",
        "lint:fix": "biome lint --fix --unsafe src/ tests/",
        "format": "biome format --write src/ tests/",
        "format:check": "biome format src/ tests/",
        "cpd": "jscpd --config .jscpd.json",
        "typecheck": "tsc --noEmit -p jsconfig.json",
        "prepare": "npm run build",
        "prepublishOnly": "npm run lint && npm run format:check && npm run typecheck && npm run build"
    },
    "peerDependencies": {
        "d3-array": "^3.2.4",
        "d3-axis": "^3.0",
        "d3-brush": "^3.0",
        "d3-chord": "^3.0",
        "d3-color": "^3.1",
        "d3-ease": "^3.0",
        "d3-geo": "^3.1.1",
        "d3-hierarchy": "^3.1",
        "d3-interpolate": "^3.0",
        "d3-sankey": "^0.12.3",
        "d3-scale": "^4.0.2",
        "d3-scale-chromatic": "^3.1.0",
        "d3-selection": "^3.0",
        "d3-shape": "^3.0",
        "d3-transition": "^3.0",
        "d3-zoom": "^3.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.11",
        "@rollup/plugin-node-resolve": "^16.0",
        "@types/d3-array": "^3.2.2",
        "@types/d3-brush": "^3.0.6",
        "@types/d3-chord": "^3.0.6",
        "@types/d3-color": "^3.1.3",
        "@types/d3-geo": "^3.1.0",
        "@types/d3-hierarchy": "^3.1.7",
        "@types/d3-scale": "^4.0.9",
        "@types/d3-scale-chromatic": "^3.1.0",
        "@types/d3-selection": "^3.0.11",
        "@types/d3-shape": "^3.1.8",
        "@types/d3-transition": "^3.0.9",
        "@types/d3-zoom": "^3.0.8",
        "@types/jest": "^30.0.0",
        "d3-array": "^3.2.4",
        "d3-axis": "^3.0",
        "d3-brush": "^3.0",
        "d3-chord": "^3.0.1",
        "d3-color": "^3.1",
        "d3-ease": "^3.0",
        "d3-geo": "^3.1.1",
        "d3-hierarchy": "^3.1.2",
        "d3-interpolate": "^3.0",
        "d3-sankey": "^0.12.3",
        "d3-scale": "^4.0.2",
        "d3-scale-chromatic": "^3.1.0",
        "d3-selection": "^3.0",
        "d3-shape": "^3.0",
        "d3-transition": "^3.0",
        "d3-zoom": "^3.0",
        "jest": "^30.0",
        "jest-environment-jsdom": "^30.0",
        "jscpd": "^4.0.9",
        "rollup": "^4.0",
        "typescript": "^6.0.3"
    },
    "author": "Rico Sonntag <mail@ricosonntag.de>",
    "license": "GPL-3.0-or-later",
    "repository": {
        "type": "git",
        "url": "https://github.com/magicsunday/webtrees-chart-lib.git"
    },
    "keywords": [
        "webtrees",
        "webtrees-module",
        "module",
        "chart",
        "library",
        "d3",
        "d3js",
        "data-visualization",
        "visualization",
        "svg",
        "javascript",
        "genealogy",
        "family-tree"
    ]
}
